<aside id="sidebar">
  <div class="sidebar-brand">Nexus Dev</div>
  <nav class="sidebar-nav">
    <a href="/" class="<%= page === 'dashboard' ? 'active' : '' %>">Dashboard</a>
    <a href="/adb" class="<%= page === 'adb' ? 'active' : '' %>">ADB</a>
    <a href="/fastboot" class="<%= page === 'fastboot' ? 'active' : '' %>">Fastboot</a>
    <a href="/screen" class="<%= page === 'screen' ? 'active' : '' %>">Screen</a>
    <a href="/camera" class="<%= page === 'camera' ? 'active' : '' %>">Camera</a>
  </nav>
  <section class="sidebar-section">
    <h3>Devices</h3>
    <div class="device-list">
      <% devices.forEach((device) => { %>
      <div class="device-chip <%= device.type %>">
        <span><%= device.name %></span>
        <small><%= device.type %></small>
      </div>
      <% }) %>
    </div>
  </section>
</aside>
