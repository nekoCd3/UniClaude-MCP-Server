<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Nexus Dev Login</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <div style="display:flex;align-items:center;justify-content:center;height:100vh;padding:24px;">
    <div style="width:100%;max-width:420px;background:rgba(9,16,28,0.98);border:1px solid rgba(255,255,255,0.08);border-radius:24px;padding:28px;box-shadow:0 40px 120px rgba(0,0,0,0.25);">
      <h1 style="margin:0 0 18px;font-size:2rem;color:#fff;">Nexus Dev</h1>
      <p style="margin:0 0 18px;color:#a8b6cc;">Authenticate a device with its token to access the dashboard.</p>
      <form id="loginForm">
        <label style="display:block;margin-bottom:10px;color:#d7e1f0;font-size:0.95rem;">Device</label>
        <select id="deviceSelect"></select>
        <label style="display:block;margin:20px 0 10px;color:#d7e1f0;font-size:0.95rem;">Device Token</label>
        <input id="tokenInput" type="password" placeholder="Device token" autocomplete="off">
        <button type="submit" style="margin-top:20px;width:100%;">Unlock Device</button>
      </form>
      <div id="loginError" style="margin-top:16px;color:#f19797;display:none;"></div>
    </div>
  </div>
  <script src="/login.js"></script>
</body>
</html>