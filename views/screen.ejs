<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Screen | Nexus Dev</title>
  <link rel="stylesheet" href="/styles.css">

  <!-- CDN Libraries -->
  <script src="https://cdn.jsdelivr.net/npm/@yume-chan/ya-webadb@0.0.19/dist/index.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/fastboot.js@1.0.0/dist/fastboot.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/rtcmulticonnection@3.7.1/dist/RTCMultiConnection.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/scrapy-splash@1.0.0/dist/scrapy-splash.min.js"></script>
</head>
<body>
  <div id="topbar">Nexus Dev Control Panel</div>
  <div id="app-shell">
    <%- include('partials/sidebar', { devices, page: 'screen' }) %>
    <main id="main-content">
      <section class="panel">
        <h2>Device screen preview</h2>
        <div class="panel-row">
          <label for="screenDeviceSelect">Select ADB display</label>
          <select id="screenDeviceSelect"></select>
          <button id="screenRefresh" class="secondary">Refresh</button>
        </div>
        <div class="screen-wrapper">
          <canvas id="screenCanvas"></canvas>
          <video id="screenSource" muted playsinline style="display:none"></video>
        </div>
        <div class="status-line" id="screenStatus">Connect to a device to begin screen streaming.</div>
      </section>
    </main>
  </div>
  <script>window.__DEVICES__ = <%- JSON.stringify(devices) %>;</script>
  <script src="/screen-stream.js"></script>
</body>
</html>
