<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ADB | Nexus Dev</title>
  <link rel="stylesheet" href="/styles.css">

  <!-- CDN Libraries -->
  <script src="https://cdn.jsdelivr.net/npm/@yume-chan/ya-webadb@0.0.19/dist/index.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/fastboot.js@1.0.0/dist/fastboot.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/rtcmulticonnection@3.7.1/dist/RTCMultiConnection.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/scrapy-splash@1.0.0/dist/scrapy-splash.min.js"></script>
</head>
<body>
  <div id="topbar">Nexus Dev Control Panel</div>
  <div id="app-shell">
    <%- include('partials/sidebar', { devices, page: 'adb' }) %>
    <main id="main-content">
      <section class="panel">
        <h2>ADB Terminal</h2>
        <div class="panel-row">
          <div>
            <label for="adbDeviceSelect">Target device</label>
            <select id="adbDeviceSelect"></select>
          </div>
          <button id="connectWebUsb" style="background: #2a8dd7;">🔌 Connect via WebUSB</button>
        </div>
        <div style="margin-bottom: 12px; color: #94a7bc; font-size: 0.9rem;">
          <strong>WebUSB Connection:</strong> Click "Connect via WebUSB" to connect Android devices directly through your browser.
          Make sure your device is in USB debugging mode.
        </div>
        <div class="terminal-panel">
          <div id="adbOutput" class="terminal-output">Choose a device and send a command.</div>
          <div class="terminal-input-row">
            <input id="adbCommandInput" placeholder="adb shell command" autocomplete="off">
            <button id="adbSendCommand">Send</button>
          </div>
        </div>
      </section>

      <section class="panel">
        <h2>File Explorer</h2>
        <div class="panel-row">
          <input id="adbFsPath" placeholder="/sdcard" value="/sdcard">
          <button id="adbRefreshFs" class="secondary">Refresh</button>
        </div>
        <div id="adbFileTree" class="file-list"></div>
      </section>

      <section class="panel">
        <h2>APK Install</h2>
        <p>Drag and drop an APK file onto the drop zone to install it on the selected ADB device.</p>
        <div id="apkDropZone" class="file-drop-zone">Drop APK here</div>
        <div id="apkStatus" class="status-line"></div>
      </section>
    </main>
  </div>
  <script>window.__DEVICES__ = <%- JSON.stringify(devices) %>;</script>
  <script src="/adb-terminal.js"></script>
  <script src="/adb-files.js"></script>
  <script src="/adb-install.js"></script>
</body>
</html>
