<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Fastboot | Nexus Dev</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <div id="topbar">Nexus Dev Control Panel</div>
  <div id="app-shell">
    <%- include('partials/sidebar', { devices, page: 'fastboot' }) %>
    <main id="main-content">
      <section class="panel">
        <h2>Fastboot Terminal</h2>
        <div class="panel-row">
          <label for="fastbootDeviceSelect">Fastboot device</label>
          <select id="fastbootDeviceSelect"></select>
        </div>
        <div class="terminal-panel">
          <div id="fastbootOutput" class="terminal-output">Enter a fastboot command to execute.</div>
          <div class="terminal-input-row">
            <input id="fastbootCommandInput" placeholder="fastboot oem unlock" autocomplete="off">
            <button id="fastbootSendCommand">Send</button>
          </div>
        </div>
      </section>

      <section class="panel">
        <h2>Flash Image</h2>
        <form id="flashForm">
          <div class="panel-row">
            <input type="text" id="flashPartition" placeholder="Partition (system, boot, recovery)" value="system">
            <input type="file" id="flashImage" accept=".img,.bin,.zip" />
          </div>
          <button type="submit">Start Flash</button>
        </form>
        <div id="fastbootFlashStatus" class="status-line"></div>
      </section>
    </main>
  </div>
  <script src="https://cdn.jsdelivr.net/gh/kdrag0n/fastboot.js@master/dist/fastboot.js"></script>
  <script src="/fastboot.js"></script>
</body>
</html>